# ============================================================
# Multi-Asset Paper Trading Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Binance Testnet API (Crypto) ----
# Get testnet keys at: https://testnet.binance.vision/
# Leave blank to disable crypto trading.
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_API_SECRET=your_binance_testnet_api_secret
BINANCE_TESTNET=true
BINANCE_RATE_LIMIT=true

# ---- PostgreSQL Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_MIN_POOL_SIZE=2
DB_MAX_POOL_SIZE=10

# ---- LLM Configuration ----
# Provider: "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Ollama (used if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LLM retry settings
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

# ---- Crypto Trading Pairs ----
# Comma-separated list of crypto pairs to trade on Binance.
# Leave empty to trade stocks/ETFs only.
TRADING_PAIRS=BTC/USDT,ETH/USDT

# ---- Stock/ETF Symbols ----
# Comma-separated list of US stock/ETF symbols to paper trade.
# Uses Yahoo Finance for real market data + simulated execution.
# No API key or brokerage account needed.
# Examples: AAPL,MSFT,GOOGL,TSLA,SPY,QQQ,NVDA,AMD,AMZN,META
STOCK_SYMBOLS=

# ---- Strategy Parameters ----
STARTING_CAPITAL=1000.0
MAX_RISK_PER_TRADE_PCT=0.02
MAX_CONCURRENT_POSITIONS=3
DAILY_HARD_STOP_PCT=-0.10

# EMA crossover settings
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21

# RSI settings
RSI_PERIOD=14
RSI_LONG_MIN=45.0
RSI_LONG_MAX=65.0
RSI_SHORT_MIN=35.0
RSI_SHORT_MAX=55.0

# ATR settings
ATR_PERIOD=14

# ---- OHLCV Data Settings ----
# Crypto timeframe (1m, 5m, 15m, 1h, 1d)
OHLCV_TIMEFRAME=1m
OHLCV_LIMIT=100
SIGNAL_CHECK_INTERVAL_SECONDS=60

# Stock timeframe (recommended: 5m or higher)
# Note: Yahoo Finance 1m data is only available during market hours
STOCK_TIMEFRAME=5m
STOCK_POLL_INTERVAL=120

# ---- Market Hours ----
# Set to true to trade stocks outside market hours (for testing only)
SKIP_MARKET_HOURS_CHECK=false

# Session schedule (UTC) — applies to crypto only
SESSION_START_HOUR_UTC=0
SESSION_END_HOUR_UTC=23
SESSION_END_MINUTE_UTC=55

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000
