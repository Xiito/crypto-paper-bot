# ============================================================
# Crypto Paper Trading Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Binance Testnet API ----
# Get testnet keys at: https://testnet.binance.vision/
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_API_SECRET=your_binance_testnet_api_secret
BINANCE_TESTNET=true
BINANCE_RATE_LIMIT=true

# ---- PostgreSQL Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_MIN_POOL_SIZE=2
DB_MAX_POOL_SIZE=10

# ---- LLM Configuration ----
# Provider: "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Ollama (used if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LLM retry settings
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

# ---- Trading Strategy Parameters ----
TRADING_PAIRS=BTC/USDT,ETH/USDT
STARTING_CAPITAL=1000.0
MAX_RISK_PER_TRADE_PCT=0.02
MAX_CONCURRENT_POSITIONS=3
DAILY_HARD_STOP_PCT=-0.10

# EMA crossover settings
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21

# RSI settings
RSI_PERIOD=14
RSI_LONG_MIN=45.0
RSI_LONG_MAX=65.0
RSI_SHORT_MIN=35.0
RSI_SHORT_MAX=55.0

# ATR settings
ATR_PERIOD=14

# OHLCV data settings
OHLCV_TIMEFRAME=1m
OHLCV_LIMIT=100

# Signal evaluation interval (seconds)
SIGNAL_CHECK_INTERVAL_SECONDS=60

# Session schedule (UTC)
SESSION_START_HOUR_UTC=0
SESSION_END_HOUR_UTC=23
SESSION_END_MINUTE_UTC=55

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000
